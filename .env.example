# ==============================================================================
# API 510 Inspection App — Local Configuration
# ==============================================================================
# Copy this to .env and customize as needed.
# With these defaults, the app runs fully offline — no data leaves your machine.

# --- Local AI (Ollama) ---
# Install Ollama: https://ollama.com/download
# Then run: ollama pull llama3.1:8b
USE_LOCAL_AI=auto          # "auto" = local if no cloud keys | "always" | "never"
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b

# --- Optional OpenAI / ChatGPT-compatible setup ---
# Point the standard AI parser at OpenAI-compatible chat completions and set the
# exact model ID you want to use. There is no separate parser dropdown for GPT models.
# BUILT_IN_FORGE_API_URL=https://api.openai.com
# BUILT_IN_FORGE_API_KEY=your-openai-key-here
# LLM_MODEL=your-openai-model-id

# --- Storage ---
# "local" saves files to ./uploads directory (no cloud needed)
STORAGE_PROVIDER=local

# --- Dev User (auto-login without OAuth) ---
# These are used when NODE_ENV != production
OWNER_OPEN_ID=dev-user
OWNER_NAME=Jerry Hartfield

# ==============================================================================
# OPTIONAL: Cloud credentials (only needed if you want cloud AI features)
# ==============================================================================
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=your-key-here
# GROK_API_KEY=your-grok-key
